{
  "permissions": {
    "allow": [
      "Bash(npx next:*)",
      "Bash(lsof -ti:3000)",
      "Bash(xargs kill:*)",
      "Bash(npx @playwright/mcp@latest --help)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000)",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_close",
      "mcp__playwright__browser_snapshot",
      "mcp__playwright__browser_take_screenshot",
      "mcp__playwright__browser_click",
      "mcp__playwright__browser_type",
      "mcp__playwright__browser_wait_for",
      "mcp__playwright__browser_console_messages",
      "Bash(curl:*)",
      "Bash(pkill -9 -f \"chromium\\\\|chrome\")",
      "Bash(pkill -9 -f \"chromium\\\\|mcp-chrome\\\\|chrome\")",
      "mcp__playwright__browser_network_requests",
      "Bash(kill 30727 30728)",
      "Bash(pkill -f \"chrome.*mcp-chrome\")",
      "Bash(pkill -f \"chromium.*mcp\")",
      "Bash(npm run:*)",
      "Bash(pkill -f \"next dev\")",
      "Bash(rm -rf .next)",
      "mcp__playwright__browser_evaluate",
      "mcp__playwright__browser_run_code",
      "Bash(node_modules/.bin/next build:*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "playwright"
  ]
}
